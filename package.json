{
  "name": "agent-control-plane",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@11.0.8",
  "scripts": {
    "build": "pnpm -r build",
    "check": "pnpm typecheck && pnpm test && pnpm build",
    "completion:audit": "node scripts/completion-audit.mjs",
    "completion:audit-smoke": "bash scripts/smoke-completion-audit.sh",
    "completion:doctor": "bash scripts/completion-doctor.sh",
    "completion:doctor-smoke": "bash scripts/smoke-completion-doctor.sh",
    "completion:final": "bash scripts/completion-final.sh",
    "completion:final-env-template": "bash scripts/completion-final-env-template.sh",
    "completion:final-env-template-smoke": "bash scripts/smoke-completion-final-env-template.sh",
    "completion:final-smoke": "bash scripts/smoke-completion-final.sh",
    "completion:gap": "bash scripts/completion-gap.sh",
    "completion:gap-smoke": "bash scripts/smoke-completion-gap.sh",
    "completion:local-smoke": "bash scripts/local-completion-smoke.sh",
    "completion:local-web-build-smoke": "bash scripts/smoke-local-web-build-retry.sh",
    "compose:smoke": "bash scripts/compose-smoke.sh",
    "codex:adapter-smoke": "bash scripts/delegate-agent-worker-smoke.sh codex:adapter-smoke",
    "codex:app-server-smoke": "bash scripts/delegate-agent-worker-smoke.sh codex:app-server-smoke",
    "cutover:check": "bash scripts/cutover-check.sh",
    "cutover:report-smoke": "bash scripts/smoke-cutover-report.sh",
    "doc-script-parity-smoke": "node scripts/check-doc-script-parity.mjs",
    "db:migrate": "pnpm --filter @agent-control-plane/db migrate:deploy",
    "db:backup": "bash scripts/db-backup.sh",
    "db:restore": "bash scripts/db-restore.sh",
    "db:seed": "pnpm --filter @agent-control-plane/db seed",
    "db:validate": "pnpm --filter @agent-control-plane/db validate",
    "deploy:compose": "bash scripts/deploy-compose.sh",
    "dev": "pnpm --filter @agent-control-plane/web dev",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "lint": "pnpm -r lint",
    "external:preflight": "bash scripts/external-smoke-preflight.sh",
    "external:preflight-smoke": "bash scripts/smoke-external-preflight.sh",
    "linear:migrate": "node scripts/linear-migrate.mjs",
    "linear:migrate-smoke": "bash scripts/smoke-linear-migration.sh",
    "operator:query-smoke": "bash scripts/smoke-operator-queries.sh",
    "openhands:payload-contract": "node scripts/openhands-payload-contract.mjs",
    "openhands:smoke": "bash scripts/smoke-openhands.sh",
    "plane:human-gate-writeback-smoke": "pnpm --filter @agent-control-plane/web test:human-gate-writeback",
    "plane:live-smoke": "bash scripts/smoke-plane-live.sh",
    "plane:live-smoke-self-test": "bash scripts/smoke-plane-live-self-test.sh",
    "plane:sync": "bash scripts/plane-sync.sh",
    "plane:sync-self-test": "node scripts/plane-sync-self-test.mjs",
    "plane:writeback-smoke": "bash scripts/smoke-plane-writeback.sh",
    "release:image": "bash scripts/release-image.sh",
    "release:image-smoke": "bash scripts/smoke-release-image.sh",
    "release:tag": "bash scripts/release-tag.sh",
    "rollback:compose": "bash scripts/rollback-compose.sh",
    "secrets:rotate": "bash scripts/rotate-secrets.sh",
    "secrets:env-smoke": "bash scripts/smoke-secret-env.sh",
    "secrets:provider-audit-smoke": "bash scripts/smoke-secret-provider-audit.sh",
    "secrets:provider-smoke": "bash scripts/smoke-secret-provider.sh",
    "secrets:validate": "bash scripts/validate-secrets.sh",
    "smoke:production": "bash scripts/smoke-production.sh",
    "task-source:local-smoke": "bash scripts/smoke-task-source-local.sh",
    "task-source:smoke": "bash scripts/smoke-task-source.sh",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "worker:contract-smoke": "pnpm --filter @agent-control-plane/web test:worker-contract",
    "worker:codex-plane-report-smoke": "bash scripts/smoke-worker-codex-plane-report.sh",
    "worker:codex-plane-smoke": "bash scripts/smoke-worker-codex-plane.sh"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "prettier": "^3.6.2",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "esbuild",
      "prisma",
      "sharp"
    ]
  }
}
