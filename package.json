{
  "name": "agent-control-plane",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@11.0.8",
  "scripts": {
    "build": "pnpm -r --if-present build",
    "check": "pnpm typecheck && pnpm test && pnpm build",
    "db:seed-demo": "pnpm --filter @agent-control-plane/db seed:demo",
    "dev": "pnpm --filter @agent-control-plane/web dev",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "health": "scripts/health-check.sh",
    "lint": "pnpm -r --if-present lint",
    "linear:migration-plan": "pnpm --filter @agent-control-plane/worker exec tsx ../../scripts/linear-to-plane-import.ts",
    "live:preflight": "pnpm --filter @agent-control-plane/worker live-preflight",
    "live:dispatch-once": "scripts/live-dispatch-once.sh",
    "live:verify-once": "scripts/live-verify-once.sh",
    "plane:probe": "pnpm --filter @agent-control-plane/worker plane-probe",
    "release:check": "scripts/release-check.sh",
    "test": "pnpm -r --if-present test",
    "typecheck": "pnpm -r --if-present typecheck",
    "worker": "pnpm --filter @agent-control-plane/worker dev",
    "worker:dry-run": "pnpm --filter @agent-control-plane/worker dry-run"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "prisma",
      "sharp"
    ]
  }
}
