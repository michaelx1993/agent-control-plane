DATABASE_URL="postgresql://agent:agent@localhost:54329/agent_control_plane"
ACP_ENV="development"
SECRET_VALIDATION_STRICT="false"
# Optional local secret store file. Use `pnpm secrets:rotate` to create it.
# File permissions must be 600 or 400 before `pnpm secrets:validate` will load it.
ACP_SECRET_ENV_FILE=""
# Optional external secret manager command. It must print dotenv lines to stdout.
# Examples: op run --env-file <file> -- printenv | grep '^ACP_'
# or: sops -d .secrets/agent-control-plane.env
ACP_SECRET_COMMAND=""
# `pnpm secrets:rotate` writes ACP_SECRET_ROTATED_AT / ACP_SECRET_EXPIRES_AT.
SECRET_ROTATION_TTL_DAYS="90"
SECRET_ROTATION_AUDIT_FILE=".secrets/rotation-audit.log"
SECRET_PROVIDER_AUDIT_FILE=""
# Optional external audit command. It must print provider audit JSONL to stdout.
SECRET_PROVIDER_AUDIT_COMMAND=""
SECRET_PROVIDER_AUDIT_EVENT_PATTERN="rotat|secret_rotation"
SECRET_PROVIDER_AUDIT_SINCE=""
SECRET_EXPIRY_WARNING_DAYS="14"

WORKER_RUN_LOOP="false"
WORKER_LOOP_INTERVAL_MS="60000"
WORKER_LEASE_TTL_MS="900000"
WORKER_LEASE_RENEWAL_INTERVAL_MS="300000"
# Optional P7 dispatch controls. Unset means unlimited.
WORKER_REPOSITORY_CONCURRENCY_LIMIT=""
WORKER_ROLE_CONCURRENCY_LIMIT=""
WORKER_AGENT_CONCURRENCY_LIMIT=""
WORKER_MAX_ESTIMATED_COST_USD_PER_RUN=""
WORKER_QUEUE_PRIORITY_POLICY="priority_aging"
WORKER_ID="local-worker"
WORKER_EXECUTION_ADAPTER="codex-cli"
WORKER_WORKSPACE_ROOT="/tmp/agent-control-plane-workspaces"
# auto: repository local_path if present, otherwise ephemeral.
# git-worktree: create a per-run worktree from repository local_path when available.
WORKER_WORKSPACE_STRATEGY="auto"
WORKSPACE_CLEANUP_RETENTION_MS="86400000"
WORKSPACE_CLEANUP_LIMIT="50"
WORKSPACE_CLEANUP_APPLY="false"
WORKER_STALLED_AFTER_MS="1200000"
WORKER_RETRY_BACKOFF_MS="300000"

MONITORING_QUEUE_BACKLOG_WARNING="20"
MONITORING_STALLED_RUNS_CRITICAL="0"
MONITORING_RETRY_BACKLOG_WARNING="0"
MONITORING_FAILURE_RATE_CRITICAL="0.5"
MONITORING_FAILURE_RATE_MIN_FINISHED="3"
MONITORING_COST_WARNING_USD="50"
MONITORING_RETRY_BACKOFF_MS="300000"
MONITORING_ALERT_WEBHOOK_URL=""
MONITORING_ALERT_MIN_INTERVAL_MS="900000"
MONITORING_ALERT_FORMAT="generic"
MONITORING_ALERT_REPLAY_LIMIT="10"
MONITORING_ALERT_RETRY_BACKOFF_MS="300000"

PLANE_BASE_URL=""
PLANE_WORKSPACE_SLUG=""
PLANE_PROJECT_ID=""
PLANE_API_KEY=""
PLANE_WEBHOOK_SECRET=""
PLANE_WRITEBACK_ENABLED="false"
PLANE_SYNC_RETRY_ATTEMPTS="3"
PLANE_SYNC_RETRY_DELAY_MS="1000"
# Optional. When true, plane:sync passes the project cursor as updated_after to
# Plane work item list calls. Keep false until the target Plane version is
# verified; unsupported 400-style responses fall back to full polling.
PLANE_SYNC_SERVER_DELTA="false"
PLANE_WRITEBACK_SMOKE_APPLY="false"
PLANE_WRITEBACK_SMOKE_WORK_ITEM_ID=""
PLANE_WRITEBACK_SMOKE_NEXT_STATE="Development"
PLANE_WRITEBACK_SMOKE_STATUS="Smoke Check"
PLANE_WRITEBACK_SMOKE_SUMMARY="Agent Control Plane Plane writeback smoke."

OPENHANDS_BASE_URL=""
OPENHANDS_API_KEY=""
OPENHANDS_SELECTED_REPOSITORY=""
# Optional event API fallback when conversation payload does not expose an
# event_log_url/events_url. Supports {conversationId} or :conversationId.
OPENHANDS_EVENT_LOG_PATH_TEMPLATE=""
OPENHANDS_SMOKE_PROBE_PATH="/api/v1/app-conversations?ids=__acp_smoke_probe__"
OPENHANDS_SMOKE_CREATE_CONVERSATION="false"
OPENHANDS_SMOKE_SELECTED_REPOSITORY=""
OPENHANDS_SMOKE_WAIT_READY="false"
OPENHANDS_SMOKE_POLL_ATTEMPTS="12"
OPENHANDS_SMOKE_POLL_INTERVAL_SECONDS="5"
# Optional. When set, openhands:smoke writes the raw conversation/event log
# contract JSON to this 0600 file for offline parser calibration.
OPENHANDS_SMOKE_PAYLOAD_FILE=""
OPENHANDS_SMOKE_EVENT_LOG_PATH_TEMPLATE=""
OPENHANDS_SMOKE_PAYLOAD_PROMPT_RELEASE_ID="openhands-smoke"
OPENHANDS_ADAPTER_SMOKE_ROLE="development"
OPENHANDS_ADAPTER_SMOKE_REPOSITORY_SLUG="aiworkspace"
OPENHANDS_ADAPTER_SMOKE_REPOSITORY_GIT_URL="git@github.com:michaelx1993/aiworkspace.git"
OPENHANDS_ADAPTER_SMOKE_PROMPT="这是 Agent Control Plane 的 OpenHands adapter smoke。请返回一条简短确认，不要修改仓库。"
OPENHANDS_ADAPTER_SMOKE_START_TIMEOUT_MS="60000"
OPENHANDS_ADAPTER_SMOKE_EXECUTION_TIMEOUT_MS="300000"
OPENHANDS_ADAPTER_SMOKE_START_POLL_INTERVAL_MS="2000"
OPENHANDS_ADAPTER_SMOKE_EXECUTION_POLL_INTERVAL_MS="5000"
OPENHANDS_DB_SMOKE_PROJECT_SLUG="token"
OPENHANDS_DB_SMOKE_REPOSITORY_SLUG="crs-src"
OPENHANDS_DB_SMOKE_IDENTIFIER=""
OPENHANDS_DB_SMOKE_EXTERNAL_TASK_ID=""
OPENHANDS_DB_SMOKE_TITLE="Agent Control Plane OpenHands database smoke"
OPENHANDS_DB_SMOKE_EXPECTED_NEXT_STATE="Code Review"
# Set true only for a dedicated smoke DB/project. It moves other automatic tasks in the project to Backlog before the smoke run.
OPENHANDS_DB_SMOKE_ISOLATE_PROJECT="false"
# Final completion requires true so DB run evidence includes trace_refs and trace_ui_url.
OPENHANDS_DB_SMOKE_EXPECT_TRACE_REF=""

LANGFUSE_ENABLED="false"
LANGFUSE_BASE_URL=""
LANGFUSE_PROJECT_ID=""
LANGFUSE_PUBLIC_KEY=""
LANGFUSE_SECRET_KEY=""
LANGFUSE_TRACING_ENVIRONMENT="dev"
LANGFUSE_RELEASE=""
LANGFUSE_SMOKE_DRY_RUN="false"

ACP_SMOKE_ENABLE_USER_WRITE="false"
ACP_SMOKE_BASE_URL="http://127.0.0.1:3112"
ACP_SMOKE_EXTERNAL="false"
ACP_SMOKE_SKIP_SECRET_VALIDATE="false"
ACP_SMOKE_REQUIRE_READINESS_DATABASE="true"
ACP_SMOKE_PLANE_EXPECTED_STATUS="200"
ACP_SMOKE_OPENHANDS_EXPECTED_STATUS="200"
ACP_SMOKE_OPENHANDS_PROBE_PATH="/api/v1/app-conversations?ids=__acp_smoke_probe__"
OPENHANDS_PAYLOAD_CONTRACT_FILE=""
ACP_SMOKE_LANGFUSE_EXPECTED_STATUS="200"
ACP_SMOKE_LANGFUSE_PROBE_PATH="/api/public/health"

# Legacy fallback for operator API auth. Prefer ACP_OPERATOR_API_TOKEN.
CONTROL_PLANE_API_TOKEN=""

ACP_OPERATOR_USER_ID="00000000-0000-4000-8000-000000000901"
ACP_OPERATOR_NAME="local-operator"
ACP_OPERATOR_ROLES="owner,prompt_admin,prompt_editor"
# Optional. When set, all operator APIs except readiness and Plane webhook require
# Authorization: Bearer <token> or x-acp-operator-token.
ACP_OPERATOR_API_TOKEN=""
ACP_OPERATOR_LOGIN_PASSWORD=""
ACP_OPERATOR_SESSION_SECRET=""
ACP_OPERATOR_SESSION_TTL_SECONDS="28800"

# Cutover gate. Keep false until the corresponding real smoke/manual action is done.
ACP_CUTOVER_PLANE_WRITEBACK_SMOKE_PASSED="false"
ACP_CUTOVER_PLANE_WRITEBACK_EVIDENCE=""
ACP_CUTOVER_OPENHANDS_SMOKE_PASSED="false"
ACP_CUTOVER_OPENHANDS_CONVERSATION_URL=""
ACP_CUTOVER_LANGFUSE_SMOKE_PASSED="false"
ACP_CUTOVER_LANGFUSE_TRACE_URL=""
ACP_CUTOVER_TASK_SOURCE_SMOKE_PASSED="false"
ACP_CUTOVER_TASK_SOURCE_EVIDENCE=""
ACP_CUTOVER_LEGACY_POLLER_READONLY="false"
ACP_CUTOVER_LEGACY_POLLER_EVIDENCE=""
ACP_CUTOVER_LINEAR_ARCHIVE_CONFIRMED="false"
ACP_CUTOVER_LINEAR_ARCHIVE_EVIDENCE=""
ACP_CUTOVER_MANUAL_EVIDENCE_SUMMARY=""
ACP_CUTOVER_SKIP_SECRET_VALIDATE="false"
ACP_CUTOVER_RUN_PRODUCTION_SMOKE="false"
ACP_CUTOVER_RUN_PLANE_WRITEBACK_SMOKE="false"
ACP_CUTOVER_RUN_OPENHANDS_SMOKE="false"
ACP_CUTOVER_RUN_OPENHANDS_ADAPTER_SMOKE="false"
ACP_CUTOVER_RUN_OPENHANDS_DB_SMOKE="false"
ACP_CUTOVER_RUN_LANGFUSE_SMOKE="false"
ACP_CUTOVER_RUN_TASK_SOURCE_SMOKE="false"
ACP_CUTOVER_RUN_WORKER_CRASH_SMOKE="false"
ACP_CUTOVER_RUN_WORKER_BUDGET_SMOKE="false"
ACP_CUTOVER_RUN_WORKER_WORKFLOW_SMOKE="false"
ACP_CUTOVER_RUN_SECRET_PROVIDER_SMOKE="false"
ACP_CUTOVER_RUN_SECRET_PROVIDER_AUDIT_SMOKE="false"
ACP_CUTOVER_RUN_EXTERNAL_PREFLIGHT="false"
# Optional. Bind external:preflight output to a final run, change ticket, or
# cutover issue. completion:final defaults this to external-preflight-<run-id>.
ACP_EXTERNAL_PREFLIGHT_ID=""
ACP_EXTERNAL_PREFLIGHT_ALLOW_MISSING="false"
ACP_EXTERNAL_PREFLIGHT_REPORT_FILE=""
# Completion gap report is a non-final diagnostic wrapper around external:preflight.
# It preserves failed preflight status and only archives missing/ready checks.
ACP_COMPLETION_GAP_ID=""
ACP_COMPLETION_GAP_REPORT_FILE=""
ACP_COMPLETION_GAP_SHOW_MISSING="false"
ACP_COMPLETION_GAP_USE_DEFAULT_ENV_FILE="true"
ACP_COMPLETION_GAP_DEFAULT_ENV_FILE=".secrets/completion-final.env"
# Optional output path for `pnpm completion:final-env-template`.
ACP_COMPLETION_FINAL_ENV_TEMPLATE_FILE=""
ACP_COMPLETION_FINAL_ENV_TEMPLATE_FORCE="false"
TASK_SOURCE_SMOKE_PROJECT_SLUG=""
TASK_SOURCE_SMOKE_LIMIT="50"
TASK_SOURCE_SMOKE_REQUIRE_SAMPLE="true"
TASK_SOURCE_SMOKE_REQUIRE_RUN_EVIDENCE="true"
TASK_SOURCE_SMOKE_REQUIRE_CONVERSATION_EVIDENCE="true"
TASK_SOURCE_SMOKE_REQUIRE_TRACE_EVIDENCE="true"
# Optional. When set, cutover:check writes a machine-readable JSON report here.
# Optional. Bind the cutover report to a final run, change ticket, or cutover
# issue. When empty, cutover:check generates a non-sensitive report id.
ACP_CUTOVER_REPORT_ID=""
ACP_CUTOVER_REPORT_FILE=""
# Keep false for final evidence. Set true only when intentionally replacing an
# existing cutover report during a controlled rerun.
ACP_CUTOVER_REPORT_OVERWRITE="false"
# Final completion wrapper. Leave blank to auto-generate a unique final run id.
ACP_COMPLETION_FINAL_RUN_ID=""
ACP_COMPLETION_FINAL_DRY_RUN="false"
# Completion audit reads the cutover report and fails until all real external
# evidence is present. Keep local evidence disabled for final completion claims.
ACP_COMPLETION_AUDIT_REPORT_FILE=""
ACP_COMPLETION_AUDIT_ALLOW_INCOMPLETE="false"
ACP_COMPLETION_AUDIT_ALLOW_LOCAL_EVIDENCE="false"
ACP_COMPLETION_AUDIT_MAX_REPORT_AGE_HOURS="24"
# auto runs Web production build when apps/web/.next/dev/lock is not held.
# true forces Web build and fails if the lock is held; false always skips it.
ACP_LOCAL_COMPLETION_RUN_WEB_BUILD="auto"
# Local-only rehearsal harness. It starts mock Plane/OpenHands/Langfuse services
# and runs cutover:check against them; it is not a production approval signal.
ACP_CUTOVER_REHEARSAL="false"
# Optional. cutover:rehearsal runs the DB-driven OpenHands smoke by default.
# Set false only when diagnosing gate wiring without database-backed worker runs.
ACP_CUTOVER_REHEARSAL_RUN_DB_SMOKE="true"
# Optional. When set, cutover:rehearsal writes and keeps its cutover report here.
# When empty, rehearsal still validates a temporary report and deletes it on exit.
ACP_CUTOVER_REHEARSAL_REPORT_FILE=""
# When DB smoke is enabled, rehearsal creates/migrates/seeds a temporary database
# by default and drops it on exit. Set false to reuse DATABASE_URL directly.
ACP_CUTOVER_REHEARSAL_TEMP_DB="true"

# Worker lease renewal smoke. Root pnpm worker:lease-smoke creates a temporary
# migrated/seeded database by default. Set false to reuse DATABASE_URL directly.
WORKER_LEASE_SMOKE_TEMP_DB="true"
WORKER_LEASE_SMOKE_DELAY_MS="1200"
WORKER_LEASE_SMOKE_LEASE_TTL_MS="2000"
WORKER_LEASE_SMOKE_RENEWAL_INTERVAL_MS="250"

# Worker crash recovery smoke. Root pnpm worker:crash-smoke creates a temporary
# migrated/seeded database by default. Set false to reuse DATABASE_URL directly.
WORKER_CRASH_SMOKE_TEMP_DB="true"
WORKER_CRASH_SMOKE_STALE_MINUTES="30"
WORKER_CRASH_SMOKE_STALLED_AFTER_MS="1000"
WORKER_CRASH_SMOKE_RETRY_BACKOFF_MS="0"

# Worker budget smoke. Root pnpm worker:budget-smoke creates a temporary
# migrated/seeded database by default. Set false to reuse DATABASE_URL directly.
WORKER_BUDGET_SMOKE_TEMP_DB="true"
WORKER_BUDGET_SMOKE_PROJECT_SLUG="token"
WORKER_BUDGET_SMOKE_REPOSITORY_SLUG="crs-src"
WORKER_BUDGET_SMOKE_ESTIMATED_COST_USD="3.5"
WORKER_BUDGET_SMOKE_MAX_ESTIMATED_COST_USD_PER_RUN="2"

# Worker workflow smoke. Root pnpm worker:workflow-smoke creates a temporary
# migrated/seeded database by default. Set false to reuse DATABASE_URL directly.
WORKER_WORKFLOW_SMOKE_TEMP_DB="true"
