{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "allowJs": false,
    "jsx": "preserve",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    "next.config.ts",
    "proxy.ts",
    "app/**/*.ts",
    "app/**/*.tsx",
    "src/**/*.ts",
    ".next/types/**/*.ts",
    "test/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
