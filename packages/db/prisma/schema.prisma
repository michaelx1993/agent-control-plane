datasource db {
  provider = "postgresql"
}

model Team {
  id               String       @id @default(uuid()) @db.Uuid
  externalProvider String       @map("external_provider")
  externalTeamId   String       @map("external_team_id")
  key              String       @unique
  name             String
  description      String?
  projects         Project[]
  auditEvents      AuditEvent[]
  createdAt        DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([externalProvider, externalTeamId])
  @@map("teams")
}

model Project {
  id                String       @id @default(uuid()) @db.Uuid
  teamId            String       @map("team_id") @db.Uuid
  team              Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  externalProjectId String       @map("external_project_id")
  slug              String
  name              String
  description       String?
  status            String       @default("active")
  repositories      Repository[]
  tasks             Task[]
  createdAt         DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([teamId, slug])
  @@unique([teamId, externalProjectId])
  @@map("projects")
}

model Repository {
  id             String          @id @default(uuid()) @db.Uuid
  projectId      String          @map("project_id") @db.Uuid
  project        Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  slug           String
  gitUrl         String          @unique @map("git_url")
  defaultBranch  String          @default("main") @map("default_branch")
  localPath      String?         @map("local_path")
  status         String          @default("active")
  description    String?
  tasks          Task[]
  promptReleases PromptRelease[]
  runs           Run[]
  workspaces     Workspace[]
  createdAt      DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([projectId, slug])
  @@map("repositories")
}

model Task {
  id               String          @id @default(uuid()) @db.Uuid
  projectId        String          @map("project_id") @db.Uuid
  project          Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  repositoryId     String?         @map("repository_id") @db.Uuid
  repository       Repository?     @relation(fields: [repositoryId], references: [id], onDelete: SetNull)
  externalTaskId   String          @map("external_task_id")
  identifier       String
  title            String
  state            String
  priority         Int?
  estimatedCostUsd Decimal?        @map("estimated_cost_usd") @db.Decimal(12, 6)
  labels           Json            @default("[]")
  assignee         String?
  url              String?
  lastSyncedAt     DateTime?       @map("last_synced_at") @db.Timestamptz(6)
  syncCursor       String?         @map("sync_cursor")
  runs             Run[]
  feedbackItems    FeedbackItem[]
  promptReleases   PromptRelease[]
  createdAt        DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([projectId, externalTaskId])
  @@unique([projectId, identifier])
  @@index([state, updatedAt])
  @@index([repositoryId, state])
  @@map("tasks")
}

model Role {
  id               String            @id @default(uuid()) @db.Uuid
  key              String            @unique
  name             String
  activeStates     String[]          @map("active_states")
  nextStates       String[]          @map("next_states")
  description      String?
  status           String            @default("active")
  agentDefinitions AgentDefinition[]
  promptReleases   PromptRelease[]
  runs             Run[]
  createdAt        DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("roles")
}

model AgentDefinition {
  id              String          @id @default(uuid()) @db.Uuid
  name            String
  roleId          String          @map("role_id") @db.Uuid
  role            Role            @relation(fields: [roleId], references: [id], onDelete: Restrict)
  runtime         String          @default("openhands")
  model           String
  reasoningEffort String          @default("high") @map("reasoning_effort")
  toolProfile     String          @map("tool_profile")
  maxTurns        Int             @default(80) @map("max_turns")
  timeoutSeconds  Int             @default(7200) @map("timeout_seconds")
  status          String          @default("active")
  promptReleases  PromptRelease[]
  runs            Run[]
  createdAt       DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("agent_definitions")
}

model PromptComponent {
  id                      String                   @id @default(uuid()) @db.Uuid
  scopeType               String                   @map("scope_type")
  scopeId                 String?                  @map("scope_id") @db.Uuid
  name                    String
  version                 Int
  status                  String                   @default("draft")
  content                 String
  changelog               String?
  author                  String?
  promptBindings          PromptBinding[]
  promptReleaseComponents PromptReleaseComponent[]
  createdAt               DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([scopeType, scopeId, name, version])
  @@map("prompt_components")
}

model PromptBinding {
  id                String          @id @default(uuid()) @db.Uuid
  scopeType         String          @map("scope_type")
  scopeId           String          @map("scope_id") @db.Uuid
  promptComponentId String          @map("prompt_component_id") @db.Uuid
  promptComponent   PromptComponent @relation(fields: [promptComponentId], references: [id], onDelete: Restrict)
  orderIndex        Int             @default(0) @map("order_index")
  environment       String          @default("dev")
  status            String          @default("pending")
  createdAt         DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([scopeType, scopeId, status])
  @@map("prompt_bindings")
}

model PromptRelease {
  id                      String                   @id @default(uuid()) @db.Uuid
  taskId                  String                   @map("task_id") @db.Uuid
  task                    Task                     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  repositoryId            String                   @map("repository_id") @db.Uuid
  repository              Repository               @relation(fields: [repositoryId], references: [id], onDelete: Restrict)
  roleId                  String                   @map("role_id") @db.Uuid
  role                    Role                     @relation(fields: [roleId], references: [id], onDelete: Restrict)
  agentDefinitionId       String                   @map("agent_definition_id") @db.Uuid
  agentDefinition         AgentDefinition          @relation(fields: [agentDefinitionId], references: [id], onDelete: Restrict)
  langfusePromptId        String?                  @map("langfuse_prompt_id")
  langfusePromptVersion   String?                  @map("langfuse_prompt_version")
  contentHash             String                   @map("content_hash")
  renderedContent         String                   @map("rendered_content")
  runs                    Run[]
  traceRefs               TraceRef[]
  promptReleaseComponents PromptReleaseComponent[]
  createdAt               DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([taskId, createdAt])
  @@index([contentHash])
  @@map("prompt_releases")
}

model PromptReleaseComponent {
  id                String          @id @default(uuid()) @db.Uuid
  promptReleaseId   String          @map("prompt_release_id") @db.Uuid
  promptRelease     PromptRelease   @relation(fields: [promptReleaseId], references: [id], onDelete: Cascade)
  promptComponentId String          @map("prompt_component_id") @db.Uuid
  promptComponent   PromptComponent @relation(fields: [promptComponentId], references: [id], onDelete: Restrict)
  orderIndex        Int             @map("order_index")
  contentHash       String          @map("content_hash")

  @@unique([promptReleaseId, orderIndex])
  @@map("prompt_release_components")
}

model Run {
  id                String             @id @default(uuid()) @db.Uuid
  taskId            String             @map("task_id") @db.Uuid
  task              Task               @relation(fields: [taskId], references: [id], onDelete: Cascade)
  repositoryId      String             @map("repository_id") @db.Uuid
  repository        Repository         @relation(fields: [repositoryId], references: [id], onDelete: Restrict)
  roleId            String             @map("role_id") @db.Uuid
  role              Role               @relation(fields: [roleId], references: [id], onDelete: Restrict)
  agentDefinitionId String             @map("agent_definition_id") @db.Uuid
  agentDefinition   AgentDefinition    @relation(fields: [agentDefinitionId], references: [id], onDelete: Restrict)
  promptReleaseId   String?            @map("prompt_release_id") @db.Uuid
  promptRelease     PromptRelease?     @relation(fields: [promptReleaseId], references: [id], onDelete: SetNull)
  status            String             @default("queued")
  leaseOwner        String?            @map("lease_owner")
  leaseExpiresAt    DateTime?          @map("lease_expires_at") @db.Timestamptz(6)
  heartbeatAt       DateTime?          @map("heartbeat_at") @db.Timestamptz(6)
  attempt           Int                @default(1)
  startedAt         DateTime?          @map("started_at") @db.Timestamptz(6)
  finishedAt        DateTime?          @map("finished_at") @db.Timestamptz(6)
  resultSummary     String?            @map("result_summary")
  failureReason     String?            @map("failure_reason")
  nextState         String?            @map("next_state")
  tokenInput        BigInt?            @map("token_input")
  tokenOutput       BigInt?            @map("token_output")
  tokenTotal        BigInt?            @map("token_total")
  costUsd           Decimal?           @map("cost_usd") @db.Decimal(12, 6)
  workspace         Workspace?
  conversationRef   ConversationRef?
  traceRefs         TraceRef[]
  runEvents         RunEvent[]
  workerApiRequests WorkerApiRequest[]
  feedbackItems     FeedbackItem[]
  createdAt         DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([taskId, createdAt])
  @@index([status, leaseExpiresAt])
  @@index([repositoryId, status])
  @@map("runs")
}

model Workspace {
  id           String     @id @default(uuid()) @db.Uuid
  runId        String     @unique @map("run_id") @db.Uuid
  run          Run        @relation(fields: [runId], references: [id], onDelete: Cascade)
  repositoryId String     @map("repository_id") @db.Uuid
  repository   Repository @relation(fields: [repositoryId], references: [id], onDelete: Restrict)
  strategy     String
  path         String
  baseRef      String?    @map("base_ref")
  headRef      String?    @map("head_ref")
  status       String     @default("preparing")
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  cleanedAt    DateTime?  @map("cleaned_at") @db.Timestamptz(6)

  @@map("workspaces")
}

model ConversationRef {
  id             String   @id @default(uuid()) @db.Uuid
  runId          String   @unique @map("run_id") @db.Uuid
  run            Run      @relation(fields: [runId], references: [id], onDelete: Cascade)
  provider       String   @default("openhands")
  conversationId String   @map("conversation_id")
  eventLogUri    String?  @map("event_log_uri")
  eventCursor    String?  @map("event_cursor")
  uiUrl          String?  @map("ui_url")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([provider, conversationId])
  @@map("conversation_refs")
}

model TraceRef {
  id              String         @id @default(uuid()) @db.Uuid
  runId           String         @map("run_id") @db.Uuid
  run             Run            @relation(fields: [runId], references: [id], onDelete: Cascade)
  provider        String         @default("langfuse")
  traceId         String         @map("trace_id")
  generationId    String?        @map("generation_id")
  model           String?
  promptReleaseId String?        @map("prompt_release_id") @db.Uuid
  promptRelease   PromptRelease? @relation(fields: [promptReleaseId], references: [id], onDelete: SetNull)
  inputTokens     BigInt?        @map("input_tokens")
  outputTokens    BigInt?        @map("output_tokens")
  costUsd         Decimal?       @map("cost_usd") @db.Decimal(12, 6)
  latencyMs       Int?           @map("latency_ms")
  uiUrl           String?        @map("ui_url")
  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([runId])
  @@index([traceId])
  @@index([promptReleaseId])
  @@map("trace_refs")
}

model RunEvent {
  id        String   @id @default(uuid()) @db.Uuid
  runId     String   @map("run_id") @db.Uuid
  run       Run      @relation(fields: [runId], references: [id], onDelete: Cascade)
  eventType String   @map("event_type")
  message   String
  payload   Json?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([runId, createdAt])
  @@index([eventType, createdAt])
  @@map("run_events")
}

model WorkerApiRequest {
  id             String   @id @default(uuid()) @db.Uuid
  workerId       String   @map("worker_id")
  runId          String   @map("run_id") @db.Uuid
  run            Run      @relation(fields: [runId], references: [id], onDelete: Cascade)
  operation      String
  idempotencyKey String   @map("idempotency_key")
  requestHash    String   @map("request_hash")
  responseStatus Int?     @map("response_status")
  responseBody   Json?    @map("response_body")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@unique([workerId, idempotencyKey])
  @@index([runId, createdAt])
  @@index([operation, createdAt])
  @@map("worker_api_requests")
}

model FeedbackItem {
  id          String    @id @default(uuid()) @db.Uuid
  taskId      String    @map("task_id") @db.Uuid
  task        Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  runId       String?   @map("run_id") @db.Uuid
  run         Run?      @relation(fields: [runId], references: [id], onDelete: SetNull)
  source      String
  severity    String    @default("info")
  body        String
  externalUrl String?   @map("external_url")
  resolvedAt  DateTime? @map("resolved_at") @db.Timestamptz(6)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([taskId, resolvedAt])
  @@index([source, createdAt])
  @@map("feedback_items")
}

model User {
  id               String       @id @default(uuid()) @db.Uuid
  externalProvider String       @map("external_provider")
  externalUserId   String       @map("external_user_id")
  name             String
  email            String?
  auditEvents      AuditEvent[]
  createdAt        DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([externalProvider, externalUserId])
  @@map("users")
}

model AppSetting {
  key         String   @id
  value       Json
  description String?
  updatedAt   DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@map("app_settings")
}

model MonitoringAlertNotification {
  id            String    @id @default(uuid()) @db.Uuid
  fingerprint   String
  level         String
  status        String    @default("pending")
  webhookUrl    String    @map("webhook_url")
  format        String    @default("generic")
  payload       Json
  attempts      Int       @default(0)
  lastError     String?   @map("last_error")
  nextAttemptAt DateTime  @default(now()) @map("next_attempt_at") @db.Timestamptz(6)
  sentAt        DateTime? @map("sent_at") @db.Timestamptz(6)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@unique([fingerprint, webhookUrl])
  @@index([status, nextAttemptAt])
  @@map("monitoring_alert_notifications")
}

model AuditEvent {
  id          String   @id @default(uuid()) @db.Uuid
  actorUserId String?  @map("actor_user_id") @db.Uuid
  actorUser   User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  teamId      String?  @map("team_id") @db.Uuid
  team        Team?    @relation(fields: [teamId], references: [id], onDelete: SetNull)
  action      String
  entityType  String   @map("entity_type")
  entityId    String   @map("entity_id") @db.Uuid
  message     String
  payload     Json?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([entityType, entityId, createdAt])
  @@index([action, createdAt])
  @@map("audit_events")
}

model AcpConfigProjectionEvent {
  id                String   @id @default(uuid()) @db.Uuid
  planeWorkspaceId  String   @map("plane_workspace_id")
  planeOutboxId     BigInt   @map("plane_outbox_id")
  entityType        String   @map("entity_type")
  entityId          String   @map("entity_id")
  projectionVersion BigInt   @map("projection_version")
  payloadHash       String   @map("payload_hash")
  status            String   @default("applied")
  error             String?
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([planeWorkspaceId, planeOutboxId])
  @@index([entityType, entityId, projectionVersion])
  @@map("acp_config_projection_events")
}

model AcpProjectProjection {
  id                      String    @id @default(uuid()) @db.Uuid
  planeProjectWorkspaceId String    @unique @map("plane_project_workspace_id")
  planeWorkspaceId        String    @map("plane_workspace_id")
  planeProjectId          String    @map("plane_project_id")
  slug                    String
  defaultWorkerId         String?   @map("default_worker_id")
  metaGitPolicy           Json      @default("{}") @map("meta_git_policy")
  projectionVersion       BigInt    @map("projection_version")
  sourceUpdatedAt         DateTime? @map("source_updated_at") @db.Timestamptz(6)
  updatedAt               DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@unique([planeWorkspaceId, slug])
  @@map("acp_project_projections")
}

model AcpUserAgentProjection {
  id                String   @id @default(uuid()) @db.Uuid
  planeUserAgentId  String   @unique @map("plane_user_agent_id")
  ownerUserId       String   @map("owner_user_id")
  name              String
  defaultModel      String   @map("default_model")
  toolProfile       Json     @default("{}") @map("tool_profile")
  configSnapshot    Json     @default("{}") @map("config_snapshot")
  projectionVersion BigInt   @map("projection_version")
  status            String   @default("active")
  updatedAt         DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@index([ownerUserId, status])
  @@map("acp_user_agent_projections")
}

model AcpPromptProjection {
  id                String   @id @default(uuid()) @db.Uuid
  planePromptId     String   @unique @map("plane_prompt_id")
  workspaceId       String   @map("workspace_id")
  name              String
  scope             String
  kind              String
  latestVersionId   String?  @map("latest_version_id")
  projectionVersion BigInt   @map("projection_version")
  status            String   @default("active")
  updatedAt         DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@index([workspaceId, scope, status])
  @@map("acp_prompt_projections")
}

model AcpPromptVersionProjection {
  id                   String   @id @default(uuid()) @db.Uuid
  planePromptVersionId String   @unique @map("plane_prompt_version_id")
  planePromptId        String   @map("plane_prompt_id")
  version              Int
  body                 String
  variables            Json     @default("{}")
  contentHash          String   @map("content_hash")
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([planePromptId, version])
  @@index([planePromptId, contentHash])
  @@map("acp_prompt_version_projections")
}

model AcpPromptBindingProjection {
  id                String   @id @default(uuid()) @db.Uuid
  planeBindingId    String   @unique @map("plane_binding_id")
  targetType        String   @map("target_type")
  targetId          String   @map("target_id")
  planePromptId     String   @map("plane_prompt_id")
  versionPolicy     String   @map("version_policy")
  pinnedVersionId   String?  @map("pinned_version_id")
  scope             String
  orderIndex        Int      @default(0) @map("order_index")
  required          Boolean  @default(true)
  status            String   @default("active")
  projectionVersion BigInt   @map("projection_version")
  updatedAt         DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@index([targetType, targetId, scope, status, orderIndex])
  @@map("acp_prompt_binding_projections")
}

model AcpWorkerCardProjection {
  id                String    @id @default(uuid()) @db.Uuid
  planeWorkerCardId String    @unique @map("plane_worker_card_id")
  planeWorkspaceId  String    @map("plane_workspace_id")
  workerId          String    @map("worker_id")
  name              String
  hostname          String?
  os                String?
  labels            Json      @default("[]")
  workspaceRoot     String?   @map("workspace_root")
  lastSeenAt        DateTime? @map("last_seen_at") @db.Timestamptz(6)
  status            String    @default("offline")
  projectionVersion BigInt    @map("projection_version")
  updatedAt         DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@unique([planeWorkspaceId, workerId])
  @@index([status, lastSeenAt])
  @@map("acp_worker_card_projections")
}

model AcpRunSnapshot {
  id           String   @id @default(uuid()) @db.Uuid
  runId        String   @unique @map("run_id") @db.Uuid
  snapshotHash String   @map("snapshot_hash")
  payload      Json
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([snapshotHash])
  @@map("acp_run_snapshots")
}

model AcpRunPipeline {
  id                     String   @id @default(uuid()) @db.Uuid
  runId                  String   @unique @map("run_id") @db.Uuid
  planePlaybookVersionId String?  @map("plane_playbook_version_id")
  status                 String   @default("active")
  createdAt              DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@map("acp_run_pipelines")
}

model AcpRunPipelineNode {
  id              String    @id @default(uuid()) @db.Uuid
  runPipelineId   String    @map("run_pipeline_id") @db.Uuid
  nodeKey         String    @map("node_key")
  nodeType        String    @map("node_type")
  roleKey         String?   @map("role_key")
  assignedAgentId String?   @map("assigned_agent_id")
  gateMode        String    @default("manual") @map("gate_mode")
  status          String    @default("pending")
  orderIndex      Int       @default(0) @map("order_index")
  inputSnapshot   Json      @default("{}") @map("input_snapshot")
  outputSummary   String?   @map("output_summary")
  startedAt       DateTime? @map("started_at") @db.Timestamptz(6)
  finishedAt      DateTime? @map("finished_at") @db.Timestamptz(6)
  updatedAt       DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@unique([runPipelineId, nodeKey])
  @@index([status, gateMode, orderIndex])
  @@map("acp_run_pipeline_nodes")
}

model AcpRunPipelineTransition {
  id            String @id @default(uuid()) @db.Uuid
  runPipelineId String @map("run_pipeline_id") @db.Uuid
  fromNodeKey   String @map("from_node_key")
  toNodeKey     String @map("to_node_key")
  condition     Json   @default("{}")
  gateMode      String @default("manual") @map("gate_mode")
  orderIndex    Int    @default(0) @map("order_index")

  @@unique([runPipelineId, fromNodeKey, toNodeKey, orderIndex], map: "acp_run_pipeline_transitions_unique_route")
  @@map("acp_run_pipeline_transitions")
}

model AcpNodeExecution {
  id                String    @id @default(uuid()) @db.Uuid
  runPipelineNodeId String    @map("run_pipeline_node_id") @db.Uuid
  runId             String    @map("run_id") @db.Uuid
  attempt           Int       @default(1)
  workerId          String?   @map("worker_id")
  status            String    @default("queued")
  startedAt         DateTime? @map("started_at") @db.Timestamptz(6)
  finishedAt        DateTime? @map("finished_at") @db.Timestamptz(6)
  resultSummary     String?   @map("result_summary")
  failureReason     String?   @map("failure_reason")
  metrics           Json      @default("{}")
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([runId, createdAt])
  @@index([status, workerId])
  @@map("acp_node_executions")
}

