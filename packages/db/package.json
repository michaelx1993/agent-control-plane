{
  "name": "@agent-control-plane/db",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "pnpm --filter @agent-control-plane/core build && pnpm validate && tsc -p tsconfig.json",
    "check": "pnpm validate && pnpm typecheck && pnpm test",
    "lint": "pnpm typecheck",
    "migrate:deploy": "prisma migrate deploy",
    "operator:query-smoke": "tsx src/operator-query-smoke.ts",
    "seed": "prisma db execute --file prisma/seed.sql",
    "test": "vitest run",
    "typecheck": "pnpm --filter @agent-control-plane/core build && tsc -p tsconfig.json --noEmit",
    "validate": "prisma validate"
  },
  "dependencies": {
    "@agent-control-plane/core": "workspace:*",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "prisma": "^7.8.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  }
}
